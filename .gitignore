################################################################
# Gitignore for ClawdOS / Agentic Candy Machine SDK
################################################################

# ----------------------------------------------------------------------------
# Secrets — NEVER commit
# ----------------------------------------------------------------------------
# Env files (any name pattern, any depth)
.env
.env.*
!.env.example
!.env.template
!.env.sample

# Private keys / certs / wallets
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
*.asc
*.gpg
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.ppk
known_hosts

# Wallet / keypair files
wallet.json
*-wallet.json
keypair.json
*-keypair.json
solana-keygen.json
phantom-export.json
agent-wallet.json

# Service account / cloud credentials
service-account*.json
gcp-credentials*.json
google-credentials*.json
firebase-adminsdk*.json
aws-credentials
credentials.json

# Coinbase / CDP specific
cdp_private_key.pem
cdp_*.pem

# Privy / other secret files
privy-private-key.pem
fly.toml.local
*api_key*.txt
*secret*.txt
client_secret_*.apps.googleusercontent.com

# ----------------------------------------------------------------------------
# Solana Finance Safety — NEVER commit
# ----------------------------------------------------------------------------
# Solana keypairs — any format, any name
*.json.bak
solana-wallet*.json
my-wallet*.json
default-wallet*.json
dev-wallet*.json
test-wallet*.json
deploy-wallet*.json
*_keypair.json
*-keypair.json
keypair*.json
id.json
# Anchor / solana-test-validator
.anchor/
test-ledger/
# Raw base58/base64 key dumps
*.b58
*.b64.key

# ----------------------------------------------------------------------------
# Clawd Agent Runtime — generated locally
# ----------------------------------------------------------------------------
# TA strategy configs
ema-cross-*.json
rsi-reversion-*.json
macd-trend-*.json
*-strategy-config.json
ta-config-*.json

# Harness config
harness.json
.clawd-harness.json
clawd-harness.json

# Context packs
*.pack.md
perps-pack.md
*-pack.md
*-context.md
clawd-context-*.md

# Vulcan strategy state
.vulcan/
vulcan-runs/
strategy-runs/
*.ledger.json
*.tick-log.json

# Paper trading state
paper-state.json
paper-balance.json
.paper/

# Imperial / perps agent session caches
imperial-session*.json
.imperial/
perps-session*.json
.perps/

# Clawd agent memory / session logs
agent-memory*.json
session-state*.json
.agent-sessions/
*.session.json

# Goals / trade records
goals-*.json
trade-record-*.json
imp-*.json

# ----------------------------------------------------------------------------
# API Keys & Tokens — belt-and-suspenders beyond .env patterns
# ----------------------------------------------------------------------------
# Specific secret file patterns (avoid broad *token*)
*-secret.json
*.secret.json
auth-token*.json
access-token*.json
bearer-token*.json
refresh-token*.json
oauth-token*.json
*-apikey.json
*-api-key.json
*-private-key.json
*-privatekey.json

# Helius / RPC / provider keys
helius*.json
helius*.env
rpc-config*.json

# ClawdRouter provisioned keys
clawd-key*.json
agent-key*.json
*-agent-key.txt

# ----------------------------------------------------------------------------
# Database & Persistent Storage — local only
# ----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
# Convex local state
.convex/

# ----------------------------------------------------------------------------
# Generated Assets & Reports
# ----------------------------------------------------------------------------
# Token launch images
launch-image-*.png
launch-image-*.jpg
launch-image-*.gif

# Audit reports / scan results
audit-report-*.json
scan-result-*.json
security-scan-*.txt

# ----------------------------------------------------------------------------
# Node / pnpm / bun
# ----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# pnpm lock is tracked at root; sub-package locks are noise
packages/*/pnpm-lock.yaml
agents/*/pnpm-lock.yaml

# ----------------------------------------------------------------------------
# Python (clawd-operator etc.)
# ----------------------------------------------------------------------------
operator/
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Build / dist artifacts
# ----------------------------------------------------------------------------
dist/
build/
!src/app/build/
!src/app/build/**
!src/app/api/build/
!src/app/api/build/**
out/
.next/
.next*/
.turbo/
.cache/
.parcel-cache/
.swc/
.tsbuildinfo
*.tsbuildinfo
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# Mobile / iOS / Android
# ----------------------------------------------------------------------------
# iOS
*.xcuserstate
xcuserdata/
DerivedData/
Pods/
*.mobileprovision
*.p8
*.ipa
*.dSYM.zip

# Android
.gradle/
local.properties
*.apk
*.aab
*.iml
captures/
google-services.json

# Expo / React Native
.expo/
.expo-shared/

# ----------------------------------------------------------------------------
# macOS / Windows / Linux junk
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Editors / IDEs
# ----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ----------------------------------------------------------------------------
# Logs / runtime / temp
# ----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock

# ----------------------------------------------------------------------------
# Test / generated data
# ----------------------------------------------------------------------------
generated/
tmp/
temp/
.tmp/

# ----------------------------------------------------------------------------
# Repo-specific
# ----------------------------------------------------------------------------
# Old/duplicate working folders
extensions copy/
agent-kit/

# Local sessions / user state
.clawdbot/
sessions/
*.session

# Sentry / sourcemaps
.sentryclirc

# Claude Code / agent local state
.claude/
.cursor/

# clawd-guard GitHub App secrets
packages/clawd-guard/.env
packages/clawd-guard/private-key.pem
packages/clawd-guard/*.pem

.playwright-mcp/
playwright-report/
test-results/

# production
es
logs/
test-output/

# umi
.umi
.umi-production
.umi-test
.dumi/tmp*

# husky
.husky/prepare-commit-msg

# extracted archives
clawd-ai-agents 2/

# macOS
__MACOSX

# Vercel
.vercel

# misc
tunnel.md
/package-lock.json

# ----------------------------------------------------------------------------
# Rust / Anchor Build Artifacts
# ----------------------------------------------------------------------------
programs/programs/target/
programs/target/
**/target/deps/
**/target/debug/
**/target/release/
**/target/sbpf-solana-solana/
.anchor/target/