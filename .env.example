# ═══════════════════════════════════════════════════════════════════════════
#  Agentic Candy Machine SDK — Environment Variables
#  Copy to .env and fill in your values. NEVER commit .env!
# ═══════════════════════════════════════════════════════════════════════════

# ─── Solana RPC ───────────────────────────────────────────────────────────
# Your RPC URL (Helius, QuickNode, Triton, or public)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Separate RPCs per cluster
# SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
# SOLANA_MAINNET_RPC_URL=https://your-rpc-provider.com

# ─── Wallet / Keypair ────────────────────────────────────────────────────
# Path to your Solana keypair JSON file (array of 64 bytes)
# SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Or provide raw secret key bytes (base58 encoded) — for CI/CD
# SOLANA_PRIVATE_KEY=

# ─── Metaplex ─────────────────────────────────────────────────────────────
# Metaplex API base URL (defaults to https://api.metaplex.com)
# METAPLEX_API_URL=https://api.metaplex.com

# ─── x402.wtf ─────────────────────────────────────────────────────────────
# x402 registry API key (optional — for registered agents)
# X402_API_KEY=

# Custom x402 registry base URL
# X402_BASE_URL=https://x402.wtf

# ─── Candy Machine ────────────────────────────────────────────────────────
# Default candy machine treasury wallet
# CANDY_MACHINE_TREASURY=

# Default creator address + share (comma-separated: addr,share;addr,share)
# CANDY_MACHINE_CREATORS=

# ─── Art / AI ─────────────────────────────────────────────────────────────
# Custom art generation endpoint (if self-hosting Stable Diffusion, etc.)
# ART_API_URL=
# ART_API_KEY=

# ─── TEE Attestation ──────────────────────────────────────────────────────
# TEE attestation service endpoint
# TEE_ATTESTATION_URL=

# ─── Token Launch ─────────────────────────────────────────────────────────
# Default token decimals
# TOKEN_DECIMALS=9

# ─── Logging ──────────────────────────────────────────────────────────────
# LOG_LEVEL=debug | info | warn | error
LOG_LEVEL=info